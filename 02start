#!/bin/bash
set -euo pipefail

# Docker Rootless   Run (execute as the target user, NOT root)
# Exports required env vars and starts the rootless Docker user service.

info()  { echo "[INFO]  $*"; }
error() { echo "[ERROR] $*" >&2; exit 1; }

[[ $EUID -eq 0 ]] && error "Do not run as root. Run as the rootless Docker user."

USER_UID=$(id -u)
export XDG_RUNTIME_DIR="/run/user/${USER_UID}"
export DOCKER_HOST="unix:///run/user/${USER_UID}/docker.sock"
export PATH="$HOME/bin:$PATH"

info "XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR"
info "DOCKER_HOST=$DOCKER_HOST"

# ── Check deps ────────────────────────────────────────────────────────────────
# ~/bin is where get.docker.com/rootless installs the binaries

for bin in docker systemctl; do
    command -v "$bin" &>/dev/null || error "Required binary not found: $bin"
done
[[ -x "$HOME/bin/dockerd-rootless.sh" ]] \
    || error "dockerd-rootless.sh not found in ~/bin   did you run the setup script?"

# ── Start and enable the user Docker service ──────────────────────────────────

if systemctl --user is-active --quiet docker; then
    info "Docker user service is already running."
else
    info "Enabling and starting docker user service..."
    systemctl --user enable --now docker && info "Docker rootless started."
fi

