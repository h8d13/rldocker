#!/bin/bash
set -euo pipefail

# Usage: ./run [--network] [image] [cmd...]
# Defaults to: alpine sh
#
# Flags:
#   --network   add NET_RAW + NET_BIND_SERVICE caps and use bridge network

export PATH="$HOME/bin:$PATH"
export DOCKER_HOST="unix:///run/user/$(id -u)/docker.sock"

# Capability allowlists based on categories
CAPS_NETWORK=(NET_RAW NET_BIND_SERVICE)

# Parse flags
CAP_ADDS=()
NETWORK="none"

while [[ "${1:-}" == --* ]]; do
    case "$1" in
        --network)
            for cap in "${CAPS_NETWORK[@]}"; do
                CAP_ADDS+=(--cap-add "$cap")
            done
            NETWORK="bridge"
            ;;
        *) echo "Unknown flag: $1" >&2; exit 1 ;;
    esac
    shift
done

IMAGE="${1:-alpine}"
shift || true

exec docker run \
    --rm \
    --interactive \
    --tty \
    --security-opt no-new-privileges \
    --cap-drop=ALL \
    "${CAP_ADDS[@]+"${CAP_ADDS[@]}"}" \
    --read-only \
    --tmpfs /tmp:rw,noexec,nosuid,size=64m \
    --network "$NETWORK" \
    "$IMAGE" "${@:-sh}"
