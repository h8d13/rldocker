#!/bin/bash
set -euo pipefail

# Docker Rootless   Install (run as the target user, NOT root)
[[ $EUID -eq 0 ]] && error "Do not run as root. Run as the user who will own the rootless daemon."

# Downloads and runs the official rootless Docker installer.
info()  { echo "[INFO]  $*"; }
error() { echo "[ERROR] $*" >&2; exit 1; }

USER_UID=$(id -u)

# ── Check prerequisites ───────────────────────────────────────────────────────

command -v curl &>/dev/null || error "curl not found."
command -v newuidmap &>/dev/null || error "newuidmap not found run docker-rootless-prereqs.sh first (as root)."
command -v newgidmap &>/dev/null || error "newgidmap not found run docker-rootless-prereqs.sh first (as root)."

for file in /etc/subuid /etc/subgid; do
    count=$(awk -F: -v u="$USER" '$1 == u {sum += $3} END {print sum+0}' "$file")
    [[ $count -ge 65536 ]] \
        || error "$file: $USER has only $count subordinate IDs (need ≥65536). Run docker-rootless-prereqs.sh first."
done

# XDG_RUNTIME_DIR: use logind's if present, else a user-owned fallback.
# Mirrors 02start so a box without logind (no /run/user/$UID) still installs.
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$USER_UID}"
if [[ ! -d "$XDG_RUNTIME_DIR" ]]; then
    export XDG_RUNTIME_DIR="$HOME/.docker/run"
    mkdir -p "$XDG_RUNTIME_DIR"
    chmod 700 "$XDG_RUNTIME_DIR"
    info "No logind runtime dir using fallback XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR"
fi

# ── Run official rootless installer ──────────────────────────────────────────

# XDG-correct install dir; upstream defaults to ~/bin which is honestly ew.
# convention is ~/.local/bin

export DOCKER_BIN="${DOCKER_BIN:-$HOME/.local/bin}"
mkdir -p "$DOCKER_BIN"

# nft-only kernels have no ip_tables.ko, so the installer's `modprobe ip_tables`
# probe fails. iptables here is the nft backend (xtables-nft) over nf_tables, so
# the legacy check is irrelevant. Skip it when ip_tables.ko is absent.
if ! modprobe -n ip_tables &>/dev/null; then
    info "ip_tables.ko absent (nft-only kernel) setting SKIP_IPTABLES=1."
    export SKIP_IPTABLES=1
fi

info "Installing to DOCKER_BIN=$DOCKER_BIN"
info "Running get.docker.com/rootless installer..."
curl -fsSL https://get.docker.com/rootless | sh

info "Install complete. Run 02start to start the daemon."
